    <Window x:Class="Participation3_EatmanCayden.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Participation3_EatmanCayden"
        mc:Ignorable="d"
        Title="Noah's Plant Application" Height="450" Width="800">

    <Grid Background="DarkGray">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="4*"/>
        </Grid.RowDefinitions>

        <!-- Labels -->
        <Label Content="Name:"
               Grid.Row="1"
               HorizontalAlignment="Right"
               VerticalAlignment="Center"
               FontSize="26"/>

        <Label Content="Environment:"
               Grid.Row="2"
               HorizontalAlignment="Right"
               VerticalAlignment="Center"
               FontSize="26"/>

        <Label Content="Type:"
               Grid.Row="3"
               HorizontalAlignment="Right"
               VerticalAlignment="Center"
               FontSize="26"/>

        <!-- Inputs -->
        <TextBox x:Name="TextBoxName"
                 Grid.Row="1"
                 Grid.Column="1"
                 Margin="5"
                 FontSize="26"/>

        <ComboBox x:Name="ComboBoxEnvironment"
                  Grid.Row="2"
                  Grid.Column="1"
                  Margin="5"
                  FontSize="26"
                  VerticalContentAlignment="Center"
                  SelectionChanged="ComboBoxEnvironment_SelectionChanged_1">
        </ComboBox>


        <ComboBox x:Name="ComboBoxType"
                  Grid.Row="3"
                  Grid.Column="1"
                  Margin="5"
                  FontSize="26"
                  VerticalContentAlignment="Center" SelectionChanged="ComboBoxType_SelectionChanged">
        </ComboBox>

        <!-- List of plants -->
        <GroupBox Header="All Plants"
                  Grid.Row="1"
                  Grid.Column="2"
                  Grid.RowSpan="3"
                  Margin="5">
            <ListBox x:Name="ListBoxPlants"
                     Margin="5"
                     FontSize="22"/>
        </GroupBox>

        <!-- Buttons -->
        <Button x:Name="ButtonAddPlant"
                Grid.Row="4"
                Grid.ColumnSpan="2"
                Content="Add Plant"
                FontSize="26"
                Margin="5"
                Click="ButtonAddPlant_Click"/>

        <Button x:Name="ButtonShowDetails"
                Grid.Row="4"
                Grid.Column="2"
                Content="Show Details"
                FontSize="26"
                Margin="5"
                Click="ButtonShowDetails_Click"/>

        <!-- Images -->
        <Image x:Name="ImageType"
               Grid.Row="5"
               Grid.ColumnSpan="2"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Stretch="Uniform"
               Source="/Images/rose.png"/>

        <Image x:Name="ImageEnvironment"
               Grid.Row="5"
               Grid.Column="2"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Stretch="Uniform"
               Source="/Images/forest.png"/>
    </Grid>
</Window>
