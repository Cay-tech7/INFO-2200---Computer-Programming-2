    <Window x:Class="Project3_CaydenEastman.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Project3_CaydenEastman"
        mc:Ignorable="d"
        Title="Cayden's Animal Application" Height="450" Width="800">
    <!--Makes the grid for the page-->
    <Grid Background="Beige">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1.3*"/>
            <RowDefinition Height="1.5*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!--Radio Buttons-->

        <RadioButton x:Name="RadioButtonDog" 
                     Content="Dog" 
                     FontSize="15"
                     Grid.Row="0" 
                     Grid.Column="1" 
                     HorizontalAlignment="Left"
                     VerticalAlignment="Center"
                     Checked="RadioButtonDog_Checked"/>

        <RadioButton x:Name="RadioButtonCoyote" 
                     Content="Coyote" 
                     FontSize="15"
                     Grid.Row="0" 
                     Grid.Column="1" 
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Checked="RadioButtonCoyote_Checked"/>

        <RadioButton x:Name="RadioButtonFerret" 
                     Content="Ferret" 
                     FontSize="15"
                     Grid.Row="0" 
                     Grid.Column="1" 
                     HorizontalAlignment="Right"
                     VerticalAlignment="Center"
                     Checked="RadioButtonFerret_Checked"/>
        
        <!--Base class Buttons-->

        <GroupBox Grid.Row="1"
                  Grid.Column="0"
                  Header="Base Class"
                  FontSize="15"
                  BorderBrush="DarkGreen"
                  BorderThickness="2">
            <StackPanel>
                <Button x:Name="ButtonMove"
                        Content="Move"
                        FontSize="15"
                        Margin="10"
                        Click="ButtonMove_Click"/>
                <Button x:Name="ButtonEat"
                        Content="Eat"
                        FontSize="15"
                        Margin="10"
                        Click="ButtonEat_Click"/>
            </StackPanel>
        </GroupBox>

        <!--Derived class Buttons-->
        <GroupBox Grid.Row="1"
                  Grid.Column="1"
                  Header="Derived Class"
                  FontSize="15"
                  BorderBrush="DarkRed"
                  BorderThickness="2">
            <StackPanel>
                <Button x:Name="ButtonPet"
                        Content="Pet"
                        FontSize="15"
                        Margin="10"
                        Click="ButtonPet_Click"/>
                
                <Button x:Name="ButtonSound"
                        Content="Sound"
                        FontSize="15"
                        Margin="10"
                        Click="ButtonSound_Click"/>
            </StackPanel>
        </GroupBox>
        
        <!--Properties class Buttons-->
        <GroupBox Grid.Row="1"
                  Grid.Column="2"
                  Header="Properties"
                  FontSize="15"
                  BorderBrush="Orange"
                  BorderThickness="2">
            <StackPanel>
                <Button x:Name="ButtonFoodType"
                        Content="Food Type"
                        FontSize="15"
                        Margin="10"
                        Click="ButtonFoodType_Click"/>
                
                <Button x:Name="ButtonSkinType"
                        Content="Skin Type"
                        FontSize="15"
                        Margin="10"
                        Click="ButtonSkinType_Click"/>
            </StackPanel>
        </GroupBox>
        
       
        <!--Image and label which will get swithed out-->
        <Image x:Name="ImageAnimal"
               Grid.Row="2"
               Grid.Column="1"
               Margin="10"
               Width="auto"
               Height="auto"
               Stretch="Uniform"
               Source="/Images/Dog.jpg"/>

        <Label x:Name="LabelResults"
               Content="Results..."
               Grid.Column="0"
               Grid.Row="3"
               Grid.ColumnSpan="3"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               FontSize="30"
               Foreground="RoyalBlue"/>


    </Grid>
</Window>
