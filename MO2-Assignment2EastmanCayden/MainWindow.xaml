<Window x:Class="MO2_Assignment2EastmanCayden.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MO2_Assignment2EastmanCayden"
        mc:Ignorable="d"
        Title="FoodSelector" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ComboBox x:Name="ComboBoxFoods"
                  Margin="75"
                  VerticalAlignment="Center"    
                  HorizontalContentAlignment="Center"
                  FontSize="30"/>

        <Button x:Name="ButtonShowFoodDetails"
                  Grid.Row="1"
                  Margin="75"
                  Content="Show Food Details"
                  FontSize="30"
                  Click="ButtonShowFoodDetails_Click"/>
    </Grid>
</Window>
