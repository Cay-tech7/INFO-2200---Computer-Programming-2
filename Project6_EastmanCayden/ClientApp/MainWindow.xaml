<Window x:Class="ClientApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClientApp"
        mc:Ignorable="d"
        Title="MainWindow" 
        Height="450" 
        Width="800"
        Icon="/uvu_icon.png">
    <StackPanel>
        <!--CLient Request Group Box-->
        <GroupBox  Header="Client Request"
                   FontSize="24"
                   Margin="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Label Content="Message the Server (Fact or Course)"
                       Grid.Row="0"
                       HorizontalAlignment="Center"
                       FontSize="18"
                       Margin="10"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Grid.Row="1">
                    
                    <TextBox x:Name="TextBoxClientRequest"
                             FontSize="14"
                             Margin="10"
                             Padding="3"
                             Width="250"
                             
                             KeyDown="TextBoxClientRequest_KeyDown"/>
                    <Button x:Name="ButtonSendClientRequest"
                            Content="Send Client Request"
                            FontSize="14"
                            Margin="10"
                            Width="150"
                            Click="ButtonSendClientRequest_Click"/>
                </StackPanel>
            </Grid>
        </GroupBox>
        
        <!--Server response groupbox-->
        <GroupBox Header="ServerResponse"
                  Margin="15"
                  FontSize="24">
            <TextBox x:Name="TextBoxServerResponse"
                     FontSize="14"
                     Height="150"
                     Margin="15"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Visible"
                     IsReadOnly="True"/>
        </GroupBox>
        
    </StackPanel>
</Window>
