<Window x:Class="Participation2_EastmanCayden.PhoneDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Participation2_EastmanCayden"
        mc:Ignorable="d"
        Title="PhoneDetailsWindow" Height="450" Width="800">
    
    <!--Outergrid-->
    <Grid>
        <!--Groupbox to group together our results-->
        <GroupBox Margin="30 30 30 100"
                  Header="Phone Details">
            <Grid>
                <!--Inner grid that actually contails all of our phone details-->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Label Content="Make:"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       FontSize="30"
                       Grid.Row="0"
                       Grid.Column="0"/>

                <Label Content="Model:"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       FontSize="30"
                       Grid.Row="1"
                       Grid.Column="0"/>

                <Label Content="Display:"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       FontSize="30"
                       Grid.Row="2"
                       Grid.Column="0"/>

                <Label Content="Storage:"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       FontSize="30"
                       Grid.Row="3"
                       Grid.Column="0"/>

                <Label Content="Price:"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   FontSize="30"
                   Grid.Row="4"
                   Grid.Column="0"/>

                <Label x:Name="LabelMake"
                       Content="Results.."
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       FontSize="30"
                       Grid.Row="0"
                       Grid.Column="1"/>

                <Label x:Name="LabelModel"
                       Content="Results.."
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       FontSize="30"
                       Grid.Row="1"
                       Grid.Column="1"/>

                <Label x:Name="LabelDisplay"
                       Content="Results.."
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       FontSize="30"
                       Grid.Row="2"
                       Grid.Column="1"/>

                <Label x:Name="LabelStorage"
                       Content="Results.."
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       FontSize="30"
                       Grid.Row="3"
                       Grid.Column="1"/>

                <Label x:Name="LabelPrice"
                       Content="Results.."
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       FontSize="30"
                       Grid.Row="4"
                       Grid.Column="1"/>

            </Grid>
        </GroupBox>

        <Button x:Name="ButtonClose"
                Content="Close"
                Margin="30"
                Padding="10"
                VerticalAlignment="Bottom"
                FontSize="30"
                Click="ButtonClose_Click"/>

    </Grid>
</Window>

